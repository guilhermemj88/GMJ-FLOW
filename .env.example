CLICKHOUSE_DATABASE=flowdb
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
BACKEND_PORT=8000
FRONTEND_PORT=8080

API_CORS_ORIGINS=*
GMJFLOW_DB_PATH=/app/data/gmjflow.db
GMJFLOW_AUTH_SECRET=change-me-gmj-flow-auth-secret
GMJFLOW_RUNTIME_DIR=/app/runtime
GMJFLOW_COLLECTORS_DIR=/app/runtime/data/collectors
GMJFLOW_COLLECTOR_APPLY_SCRIPT=/app/runtime/scripts/apply_collectors.sh
GMJFLOW_ENABLE_COLLECTOR_APPLY=false
GMJFLOW_SNMP_POLLING_ENABLED=1
GMJFLOW_CALIBRATION_MIN_BPS=10000
GMJFLOW_CALIBRATION_MIN_CONFIDENCE=0.6
GMJFLOW_MAX_RANGE_MINUTES=259200
GMJFLOW_ANOMALY_DETECTION_ENABLED=true
GMJFLOW_ANOMALY_INTERVAL_SECONDS=30
GMJFLOW_ANOMALY_LOOKBACK_SECONDS=60
GMJFLOW_ANOMALY_MIN_DURATION_SECONDS=30
GMJFLOW_ANOMALY_CLOSE_AFTER_SECONDS=120
GMJFLOW_ASN_RESOLVER_ENABLED=true
GMJFLOW_ASN_RESOLVER_INTERVAL_SECONDS=86400
GMJFLOW_ASN_RESOLVER_MAX_IPS_PER_RUN=5000
GMJFLOW_ASN_CACHE_TTL_SECONDS=604800

FAKE_FLOW_BATCH_SIZE=1000
FAKE_FLOW_INTERVAL_SECONDS=5

NETFLOW_PORT=9995
PMACCT_SENSOR=mikrotik-lab
PMACCT_EXPORTER_IP=192.168.0.157
PMACCT_OUTPUT_FILE=/var/spool/pmacct/nfacctd.csv
PMACCT_OUTPUT_FORMAT=csv
PMACCT_CSV_DELIMITER=,
PMACCT_CSV_FIELDS=src_host,dst_host,src_port,dst_port,proto,tcpflags,in_iface,out_iface,src_as,dst_as,timestamp,packets,bytes,flows
PMACCT_SAMPLE_RATE=1
PMACCT_PARSER_BATCH_SIZE=1000
PMACCT_PARSER_FLUSH_SECONDS=5
