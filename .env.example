CLICKHOUSE_DATABASE=flowdb
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=5
CLICKHOUSE_QUERY_TIMEOUT_SECONDS=30
CLICKHOUSE_ADMIN_TIMEOUT_SECONDS=300
BACKEND_PORT=8000
FRONTEND_PORT=8080

API_CORS_ORIGINS=*
GMJFLOW_DB_PATH=/app/data/gmjflow.db
GMJFLOW_AUTH_SECRET=change-me-gmj-flow-auth-secret
GMJFLOW_RUNTIME_DIR=/app/runtime
GMJFLOW_PROJECT_DIR=/home/noc/GMJ-FLOW/GMJ-FLOW
GMJFLOW_DOCKER_NETWORK=gmj-flow_default
GMJFLOW_COLLECTORS_DIR=
GMJFLOW_COLLECTOR_APPLY_SCRIPT=/app/runtime/scripts/apply_collectors.sh
GMJFLOW_ENABLE_COLLECTOR_APPLY=true
GMJFLOW_SNMP_POLLING_ENABLED=1
GMJFLOW_CALIBRATION_MIN_BPS=10000
GMJFLOW_CALIBRATION_MIN_CONFIDENCE=0.6
GMJFLOW_MAX_RANGE_MINUTES=259200
GMJFLOW_ANOMALY_DETECTION_ENABLED=true
GMJFLOW_ANOMALY_INTERVAL_SECONDS=30
GMJFLOW_ANOMALY_LOOKBACK_SECONDS=60
GMJFLOW_ANOMALY_MIN_DURATION_SECONDS=30
GMJFLOW_ANOMALY_CLOSE_AFTER_SECONDS=120
GMJFLOW_ASN_RESOLVER_ENABLED=true
GMJFLOW_ASN_RESOLVER_BATCH_SIZE=20
GMJFLOW_ASN_RESOLVER_INTERVAL_SECONDS=30
GMJFLOW_ASN_RESOLVER_TIMEOUT_SECONDS=10
GMJFLOW_ASN_RESOLVER_MAX_ATTEMPTS=3
GMJFLOW_ASN_CACHE_TTL_DAYS=30
GMJFLOW_GEOIP_MMDB_PATH=/app/data/GeoLite2-City.mmdb

AI_MITIGATION_ENABLED=false
AI_PROVIDER=ollama
AI_BASE_URL=http://gmj-flow-ollama:11434
AI_MODEL_PROFILE=recommended
AI_MODEL=qwen2.5:3b-instruct
AI_TIMEOUT_SECONDS=20
AI_MAX_TOP_FLOWS=30
AI_MAX_CONTEXT_CHARS=12000
AI_ALLOW_AUTO=false
AI_REQUIRE_POLICY_VALIDATION=true

FAKE_FLOW_BATCH_SIZE=1000
FAKE_FLOW_INTERVAL_SECONDS=5

NETFLOW_PORT=9995
PMACCT_SENSOR=mikrotik-lab
PMACCT_EXPORTER_IP=192.168.0.157
PMACCT_OUTPUT_FILE=/var/spool/pmacct/nfacctd.csv
PMACCT_OUTPUT_FORMAT=csv
PMACCT_CSV_DELIMITER=,
PMACCT_CSV_FIELDS=src_as,dst_as,in_iface,out_iface,src_host,dst_host,src_port,dst_port,tcpflags,proto,timestamp_start,packets,bytes
PMACCT_SAMPLE_RATE=1
PMACCT_PARSER_BATCH_SIZE=1000
PMACCT_PARSER_FLUSH_SECONDS=5
PMACCT_STATE_DIR=/var/spool/pmacct/state
PMACCT_PARSER_START_FROM_END_IF_NO_STATE=true
GMJFLOW_PMACCT_ROTATE_ENABLED=true
GMJFLOW_PMACCT_ROTATE_MAX_MB=100
GMJFLOW_PMACCT_ROTATE_KEEP_DAYS=3
GMJFLOW_PMACCT_ROTATE_COMPRESS=true
GMJFLOW_PMACCT_ROTATE_CHECK_SECONDS=30
